{
    "name": "hihaho/rector-rules",
    "description": "Hihaho Rector rules for auto-fixing code conventions",
    "homepage": "https://guidelines.hihaho.com",
    "type": "rector-extension",
    "license": "MIT",
    "keywords": [
        "rector",
        "rector-rules",
        "rector-extension",
        "laravel",
        "code-style",
        "conventions",
        "static-analysis",
        "hihaho"
    ],
    "support": {
        "issues": "https://github.com/hihaho/rector-rules/issues",
        "source": "https://github.com/hihaho/rector-rules",
        "docs": "https://guidelines.hihaho.com"
    },
    "autoload": {
        "psr-4": {
            "Hihaho\\RectorRules\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hihaho\\RectorRules\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "hihaho",
            "email": "info@hihaho.com",
            "homepage": "https://www.hihaho.com/",
            "role": "Organisation"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": "^8.3",
        "rector/rector": "^2.4.1",
        "symplify/rule-doc-generator-contracts": "^11.2"
    },
    "require-dev": {
        "laravel/boost": "^2.4",
        "laravel/pint": "^1.29",
        "nikic/php-parser": "^5.4",
        "orchestra/testbench": "^10.11||^11.0",
        "pestphp/pest": "^4.4",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^12.0",
        "rector/type-perfect": "^2.0",
        "roave/security-advisories": "dev-latest",
        "sandermuller/boost-skills": "^2.4",
        "sandermuller/package-boost-laravel": "^1.0",
        "spaze/phpstan-disallowed-calls": "^4.10",
        "symplify/phpstan-extensions": "^12.0",
        "tomasvotruba/cognitive-complexity": "^1.0",
        "tomasvotruba/type-coverage": "^2.0"
    },
    "suggest": {
        "illuminate/support": "Used by AssertDatabaseTableToModelClassRector to resolve table names; always present in the Laravel projects this package targets"
    },
    "scripts": {
        "format": "vendor/bin/pint",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "rector": "vendor/bin/rector process",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "qa": ["@format", "@rector", "@phpstan"],
        "sync-ai": "vendor/bin/boost sync",
        "post-install-cmd": [
            "SanderMuller\\PackageBoostLaravel\\Scripts\\AutoSync::run"
        ],
        "post-update-cmd": [
            "SanderMuller\\PackageBoostLaravel\\Scripts\\AutoSync::run"
        ]
    },
    "extra": {
        "rector": {
            "includes": [
                "config/config.php"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true,
            "rector/extension-installer": true
        },
        "sort-packages": true
    }
}
